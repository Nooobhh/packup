# 高德 Web 服务 REST Key, used by server-side POI search and routing.
AMAP_REST_KEY=

# 高德 JS SDK Key, used by the browser map component.
NEXT_PUBLIC_AMAP_JS_KEY=

# 高德 JS SDK 安全密钥(2021+ 必配,与 JS Key 成对), set as window._AMapSecurityConfig before SDK load.
NEXT_PUBLIC_AMAP_SECURITY_CODE=

# pptoken 中转站 API key（OpenAI 兼容，https://api.pptoken.cc/v1），parse-query / extract / plan 三段默认走它调 gpt-5.6（必填）。
PACKUP_PPTOKEN_API_KEY=

# DeepSeek API key，备用 provider（router.ts 切回 deepseek 时才需要）。
PACKUP_DEEPSEEK_API_KEY=

# 本机 claude CLI 模型名，备用 provider（router.ts 切回 claude-cli 时才需要）；不填走 `sonnet`。
PACKUP_CLAUDE_MODEL=sonnet

# 可选：全站 Basic Auth（"用户名:密码" 格式），自部署公网裸端口时防扫描/防蹭额度；不设则不启用。
PACKUP_BASIC_AUTH=
