# 高德 Web 服务 REST Key, used by server-side POI search and routing.
AMAP_REST_KEY=

# 高德 JS SDK Key, used by the browser map component.
NEXT_PUBLIC_AMAP_JS_KEY=

# 高德 JS SDK 安全密钥(2021+ 必配,与 JS Key 成对), set as window._AMapSecurityConfig before SDK load.
NEXT_PUBLIC_AMAP_SECURITY_CODE=

# DeepSeek API key，parse-query / plan 两段通过它调 DeepSeek Chat Completions（PACKUP_DEEPSEEK_API_KEY 必填）。
PACKUP_DEEPSEEK_API_KEY=

# 本机 claude CLI 模型名，extract 段（多模态）用；不填走 `sonnet`。
PACKUP_CLAUDE_MODEL=sonnet
